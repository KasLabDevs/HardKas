{
  "schema": "hardkas.toccataGoldenFailureCase.v1",
  "caseId": "mainnet-guard",
  "title": "Deploy plan attempts to target mainnet",
  "network": "mainnet",
  "profile": "toccata-v2",
  "baseArtifact": "../op-true/deploy-plan.json",
  "input": {
    "artifactSchema": "hardkas.silver.deployPlan",
    "mutation": {
