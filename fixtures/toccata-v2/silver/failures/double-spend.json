{
  "schema": "hardkas.toccataGoldenFailureCase.v1",
  "caseId": "double-spend",
  "title": "Spend plan attempts to spend the same synthetic UTXO twice",
  "network": "simnet",
  "profile": "toccata-v2",
  "baseArtifact": "../op-true/spend-plan.json",
  "stateSetup": {
    "deployPlan": "../op-true/deploy-plan.json",
    "deploySimulationReceipt": "../op-true/deploy-simulated.json",
    "simulatorSpendInputNormalization": [
      {
        "path": "$.deployArtifactHash",
        "valueFrom": "../op-true/deploy-simulated.json#$.contentHash"
      },
      {
        "path": "$.contractUtxoRef",
        "valueFrom": "../op-true/deploy-simulated.json#$.syntheticOutpoint"
      }
    ]
  },
  "input": {
    "artifactSchema": "hardkas.silver.spendPlan",
    "mutation": {
      "type": "state-transition",
      "description": "Apply the OP_TRUE spend plan once, then replay the same spend plan against the resulting state."
    }
  },
  "expectedSimulator": {
    "phase": "simulateSilverSpend",
    "firstAttempt": {
      "status": "SIMULATED_ACCEPTED"
    },
    "secondAttempt": {
      "status": "REJECTED",
      "error": "SILVERSCRIPT_UTXO_ALREADY_SPENT"
    }
  },
  "expectedReal": {
    "status": "NODE_REJECTS_OR_MEMPOOL_REJECTS",
    "reason": "A real Docker replay spends an already-consumed outpoint and must not become an accepted lifecycle receipt."
  },
  "compare": {
    "status": "NOT_APPLICABLE_INPUT_REJECTED",
    "reason": "The second spend has no accepted simulator receipt to compare."
  }
}
