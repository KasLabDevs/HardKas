{
  "name": "superapp-command-center",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx backend/src/index.ts",
    "dev:backend": "tsx watch backend/src/index.ts",
    "dev:frontend": "cd frontend && vite",
    "build:frontend": "cd frontend && vite build",
    "test": "pnpm -w vitest run examples/superapp-command-center/tests/backend",
    "test:watch": "pnpm -w vitest examples/superapp-command-center/tests/backend",
    "test:frontend": "playwright test tests/frontend",
    "coverage": "pnpm -w vitest run examples/superapp-command-center/tests/backend --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@hardkas/core": "workspace:*",
    "@hardkas/observability": "workspace:*",
    "@hardkas/plugin-rpc-backend": "workspace:*",
    "@hardkas/sdk": "workspace:*",
    "@hardkas/storage-sqlite": "workspace:*",
    "@hardkas/sync-daemon": "workspace:*",
    "@hardkas/toolkit": "workspace:*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@hardkas/node-runner": "workspace:0.11.1-alpha",
    "@playwright/test": "^1.60.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.19.19",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.2.0"
  }
}
