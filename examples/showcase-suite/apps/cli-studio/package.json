{
  "name": "@showcase/cli-studio",
  "private": true,
  "version": "0.11.2-alpha",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "dev:frontend": "vite --port 4070",
    "dev:backend": "tsx watch src/backend/server.ts",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "@hardkas/cli": "workspace:0.11.2-alpha",
    "@hardkas/core": "workspace:0.11.2-alpha",
    "@hardkas/kaspa-rpc": "workspace:0.11.2-alpha",
    "@hardkas/toolkit": "workspace:0.11.2-alpha",
    "@hardkas/tx-builder": "workspace:0.11.2-alpha",
    "@hardkas/wallet-adapter": "workspace:0.11.2-alpha",
    "@showcase/shared-backend": "workspace:*",
    "@showcase/shared-testkit": "workspace:^",
    "@showcase/shared-ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}

