{
  "name": "Demo Local Transfer",
  "version": "1.0",
  "description": "A minimal, reproducible demo workflow showing deterministic local transaction planning, simulation, and execution.",
  "allowNetwork": true,
  "steps": [
    {
      "type": "network.switch",
      "args": {
        "network": "simulated"
      }
    },
    {
      "type": "tx.plan",
      "args": {
        "from": "demo-sender",
        "to": "demo-receiver",
        "amount": "100"
      }
    },
    {
      "type": "tx.simulate"
    },
    {
      "type": "tx.send"
    }
  ]
}
