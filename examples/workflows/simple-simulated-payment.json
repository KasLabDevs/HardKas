{
  "name": "Simple Payment Automation",
  "description": "Plans and executes a simple deterministic transfer",
  "allowNetwork": true,
  "steps": [
    {
      "type": "tx.plan",
      "args": {
        "from": "alice",
        "to": "bob",
        "amount": "100"
      }
    },
    {
      "type": "tx.simulate",
      "args": {
        "autoSign": true
      }
    }
  ]
}
