{
  "name": "Multi Step Orchestration",
  "description": "Plans, signs, and executes multiple transfers sequentially",
  "allowNetwork": true,
  "steps": [
    {
      "type": "tx.plan",
      "args": {
        "from": "carol",
        "to": "alice",
        "amount": "5000"
      }
    },
    {
      "type": "tx.simulate",
      "args": {
        "autoSign": true
      }
    },
    {
      "type": "tx.plan",
      "args": {
        "from": "alice",
        "to": "bob",
        "amount": "100"
      }
    },
    {
      "type": "tx.simulate",
      "args": {
        "autoSign": true
      }
    }
  ]
}
