{
  "name": "@hardkas/localnet",
  "version": "0.8.12-alpha",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external kaspa-wasm",
    "dev": "tsup src/index.ts --format esm --watch --dts --external kaspa-wasm",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hardkas/artifacts": "workspace:*",
    "@hardkas/core": "workspace:*",
    "@hardkas/kaspa-rpc": "workspace:*",
    "@hardkas/query": "workspace:*",
    "@hardkas/simulator": "workspace:*",
    "@hardkas/tx-builder": "workspace:*",
    "kaspa-wasm": "0.13.0"
  },
  "devDependencies": {
    "fast-check": "^4.8.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "author": "Javier Rodriguez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KasLabDevs/HardKas.git",
    "directory": "packages/localnet"
  },
  "bugs": {
    "url": "https://github.com/KasLabDevs/HardKas/issues"
  },
  "homepage": "https://github.com/KasLabDevs/HardKas/tree/main/packages/localnet#readme",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}
