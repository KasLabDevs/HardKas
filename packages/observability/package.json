{
  "name": "@hardkas/observability",
  "version": "0.11.1-alpha",
  "description": "Zero-dependency telemetry, logging, and metrics for HardKAS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}
