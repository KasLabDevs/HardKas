{
  "name": "@hardkas/pskt-native",
  "version": "0.11.4-alpha",
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "hardkas-pskt-native",
    "triples": {
      "additional": [
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "engines": {
    "node": ">= 22.5.0"
