{
  "name": "@hardkas/accounts",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external kaspa",
    "dev": "tsup src/index.ts --format esm --watch --dts --external kaspa",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hardkas/artifacts": "workspace:*",
    "@hardkas/config": "workspace:*",
    "@hardkas/core": "workspace:*",
    "@hardkas/localnet": "workspace:*",
    "hash-wasm": "^4.12.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "author": "Javier Rodriguez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KasLabDevs/HardKas.git",
    "directory": "packages/accounts"
  },
  "bugs": {
    "url": "https://github.com/KasLabDevs/HardKas/issues"
  },
  "homepage": "https://github.com/KasLabDevs/HardKas/tree/main/packages/accounts#readme"
}
