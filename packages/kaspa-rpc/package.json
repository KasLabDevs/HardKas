  "scripts": {
    "build": "tsup src/index.ts src/adapters/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hardkas/core": "workspace:*",
