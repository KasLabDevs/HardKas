{
  "name": "@hardkas/testing",
  "version": "0.3.0-alpha",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./harness": "./dist/harness.js",
    "./setup": "./dist/setup.js",
    "./adversarial-fixtures": "./dist/adversarial-fixtures.js",
    "./mass-setup": "./dist/mass-setup.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/harness.ts src/setup.ts src/reproducibility.ts src/adversarial-fixtures.ts src/mass-setup.ts --format esm --dts --clean --external vitest",
    "test": "vitest run && pnpm test:gauntlet",
    "test:gauntlet": "node --import tsx --test test/gauntlet.node.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hardkas/artifacts": "workspace:*",
    "@hardkas/core": "workspace:*",
    "@hardkas/kaspa-rpc": "workspace:*",
    "@hardkas/localnet": "workspace:*",
    "@hardkas/query-store": "workspace:*",
    "@hardkas/sdk": "workspace:*",
    "@hardkas/simulator": "workspace:*",
    "@hardkas/tx-builder": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "author": "Javier Rodriguez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KasLabDevs/HardKas.git",
    "directory": "packages/testing"
  },
  "bugs": {
    "url": "https://github.com/KasLabDevs/HardKas/issues"
  },
  "homepage": "https://github.com/KasLabDevs/HardKas/tree/main/packages/testing#readme",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ]
}
