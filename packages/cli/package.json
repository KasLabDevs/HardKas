{
  "name": "@hardkas/cli",
  "version": "0.8.20-alpha",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./bin": "./dist/index.js"
  },
  "files": [
    "dist",
    "dashboard-dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "hardkas": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/public.ts --format esm --dts --clean --external vitest",
    "dev": "tsx src/index.ts",
    "hardkas": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "docs:generate-cli": "tsx src/scripts/generate-cli-docs.ts",
    "docs:check-cli": "tsx src/scripts/generate-cli-docs.ts --check",
    "test": "vitest run",
    "test:docs": "tsx test/docs-drift.node.ts",
    "test:examples": "node --import tsx --test test/examples-acceptance.node.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hardkas/accounts": "0.8.20-alpha",
    "@hardkas/artifacts": "0.8.20-alpha",
    "@hardkas/bridge-local": "0.8.20-alpha",
    "@hardkas/config": "0.8.20-alpha",
    "@hardkas/core": "0.8.20-alpha",
    "@hardkas/dev-server": "0.8.20-alpha",
    "@hardkas/kaspa-rpc": "0.8.20-alpha",
    "@hardkas/l2": "0.8.20-alpha",
    "@hardkas/localnet": "0.8.20-alpha",
    "@hardkas/node-orchestrator": "0.8.20-alpha",
    "@hardkas/node-runner": "0.8.20-alpha",
    "@hardkas/query": "0.8.20-alpha",
    "@hardkas/query-store": "0.8.20-alpha",
    "@hardkas/sdk": "0.8.20-alpha",
    "@hardkas/sessions": "0.8.20-alpha",
    "@hardkas/simulator": "0.8.20-alpha",
    "@hardkas/testing": "0.8.20-alpha",
    "@hardkas/tx-builder": "0.8.20-alpha",
    "@kaspa/core-lib": "^1.6.5",
    "commander": "^12.1.0",
    "enquirer": "^2.4.1",
    "execa": "^9.5.2",
    "express": "^5.2.1",
    "open": "^10.1.0",
    "picocolors": "^1.1.1",
    "viem": "^2.21.32",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "author": "Javier Rodriguez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KasLabDevs/HardKas.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/KasLabDevs/HardKas/issues"
  },
  "homepage": "https://github.com/KasLabDevs/HardKas/tree/main/packages/cli#readme"
}