{
  "name": "@hardkas/cli",
  "version": "0.2.2-alpha.1",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "hardkas": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --external vitest",
    "dev": "tsx src/index.ts",
