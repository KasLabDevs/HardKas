{
  "name": "@hardkas/sdk",
  "version": "0.8.2-alpha",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/client.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hardkas/accounts": "workspace:*",
    "@hardkas/artifacts": "workspace:*",
    "@hardkas/config": "workspace:*",
    "@hardkas/core": "workspace:*",
    "@hardkas/kaspa-rpc": "workspace:*",
    "@hardkas/l2": "workspace:*",
    "@hardkas/localnet": "workspace:*",
    "@hardkas/query": "workspace:*",
    "@hardkas/simulator": "workspace:*",
    "@hardkas/tx-builder": "workspace:*",
    "@hardkas/wallet-adapter": "workspace:*",
    "@hardkas/query-store": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "@types/node": "^20.12.7",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT",
  "author": "Javier Rodriguez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KasLabDevs/HardKas.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/KasLabDevs/HardKas/issues"
  },
  "homepage": "https://github.com/KasLabDevs/HardKas/tree/main/packages/sdk#readme"
}
