{
  "browserCompatible": [],
  "nodeOnly": [
    "Hardkas.create",
    "artifacts.list",
    "tx.plan",
    "tx.sign",
    "query.sync"
  ],
  "nodeOnlyReasons": {
    "Hardkas.create": "Requires fs/path to read hardkas.config.ts and sqlite for db",
    "artifacts.list": "Requires fs to read .hardkas/artifacts",
    "tx.plan": "Requires crypto for hashing and fs for persistence",
    "query.sync": "Requires better-sqlite3 native bindings"
  },
  "missingForReact": [
    {
      "package": "@hardkas/client",
      "methods": [
        "artifacts.list",
        "artifacts.get",
        "accounts.list",
        "accounts.balance",
        "tx.plan",
        "tx.send",
        "query.events",
        "replay.verify",
        "lineage.trace"
      ]
    },
    {
      "package": "@hardkas/react",
      "hooks": [
        "useHardkas",
        "useArtifacts",
        "useArtifact",
        "useAccounts",
        "useBalance",
        "useTxPlan",
        "useTxSend",
        "useLineage",
        "useReplay",
        "useQueryEvents"
      ]
    }
  ],
  "recommendedArchitecture": "React -> @hardkas/client -> Node backend -> @hardkas/sdk"
}