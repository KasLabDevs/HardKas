{
  "name": "hardkas-monorepo",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Javier Rodriguez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KasLabDevs/HardKas.git"
  },
  "homepage": "https://github.com/KasLabDevs/HardKas#readme",
  "engines": {
    "node": ">=22.5.0"
  },
  "bugs": {
    "url": "https://github.com/KasLabDevs/HardKas/issues"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "pnpm -r test && pnpm test:workflows",
    "test:workflows": "vitest run packages/cli/test/workflow-corpus.test.ts",
    "test:fuzz": "vitest run packages/testing/test/fuzz-policy.test.ts packages/testing/test/fuzz-network.test.ts packages/testing/test/fuzz-migration.test.ts",
    "test:fuzz:policy": "vitest run packages/testing/test/fuzz-policy.test.ts",
    "test:fuzz:network": "vitest run packages/testing/test/fuzz-network.test.ts",
    "test:fuzz:migration": "vitest run packages/testing/test/fuzz-migration.test.ts",
    "test:backward": "vitest run packages/testing/test/backward-compat.test.ts",
    "smoke:backward": "tsx packages/testing/scripts/smoke-backward-compat.ts",
    "packaging:smoke": "node scripts/packaging-smoke.mjs",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "docs:generate-cli": "pnpm --filter @hardkas/cli docs:generate-cli",
    "docs:check-cli": "pnpm --filter @hardkas/cli docs:check-cli",
    "hardkas": "pnpm --filter @hardkas/cli run dev",
    "cli": "pnpm --filter @hardkas/cli run dev",
    "check": "pnpm typecheck && pnpm build && pnpm version:check && pnpm docs:check-cli && pnpm check:docs && pnpm test",
    "test:repro": "pnpm --filter @hardkas/testing test",
    "version:check": "node scripts/check-versions.mjs",
    "release:dry-run": "pnpm version:check && pnpm build && pnpm test && pnpm changeset status",
    "release": "pnpm version:check && pnpm build && pnpm test && pnpm changeset publish",
    "check:docs": "pnpm --filter @hardkas/cli test:docs",
    "check:artifacts": "pnpm artifact:fixtures",
    "artifact:fixtures": "pnpm hardkas artifact verify ../artifacts/test/fixtures/valid --recursive --strict",
    "artifact:corruption": "pnpm hardkas artifact verify ../artifacts/test/fixtures/corrupted --recursive --strict",
    "example:hello": "tsx examples/01-hello-kaspa/main.ts",
    "example:transfer": "tsx examples/02-basic-transfer/main.ts",
    "example:localnet": "tsx examples/03-localnet-demo/main.ts",
    "example:trace": "pnpm --filter @examples/trace-and-replay start",
    "example:snapshot": "pnpm --filter @examples/snapshot-restore start",
    "example:rpc-health": "pnpm --filter @examples/rpc-node-health start",
    "example:failure": "pnpm --filter @examples/failure-debugging start",
    "example:igra-readonly": "pnpm --filter @examples/igra-l2-readonly start",
    "example:bridge-assumptions": "pnpm --filter @examples/bridge-assumptions start",
    "example:ci": "pnpm --filter @examples/ci-workflow start",
    "example:dag-reorg": "pnpm --filter @examples/dag-reorg-simulation start",
    "examples:test": "pnpm --filter @examples/basic-transfer start && pnpm --filter @examples/backend-service start && pnpm --filter @examples/audit-pipeline start && pnpm --filter @examples/replay start && pnpm --filter @examples/policy start",
    "docs:check": "node scripts/docs-check.mjs",
    "gauntlet:toccata": "node scripts/toccata-gauntlet.mjs",
    "corpus:toccata": "tsx packages/cli/src/index.ts corpus verify fixtures/toccata-v2/silver --json --workspace .",
    "zk:corpus": "tsx packages/cli/src/index.ts zk corpus verify fixtures/toccata-v2/zk --json",
    "vprogs:check": "node scripts/vprogs-check.mjs",
    "programmability:corpus": "tsx packages/cli/src/index.ts programmability corpus verify fixtures/toccata-v2 --json",
    "programmability:examples": "node scripts/programmability-examples.mjs",
    "programmability:templates": "node scripts/programmability-templates.mjs",
    "programmability:surface": "node scripts/programmability-surface.mjs",
    "postrelease:break": "node scripts/post-release-break-gauntlet.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@hardkas/config": "^0.1.0",
    "@hardkas/core": "^0.1.0",
    "@hardkas/sdk": "^0.1.0",
    "@types/node": "^22.19.19",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.3",
    "vitest": "^2.1.9"
  },
  "version": "0.9.3-alpha",
  "dependencies": {
    "kaspa": "^0.13.0",
    "kaspa-wasm": "^0.13.0"
  }
}
